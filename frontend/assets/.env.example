# API Configuration
# For Android Emulator: http://10.0.2.2:8000/api
# For iOS Simulator: http://localhost:8000/api or http://127.0.0.1:8000/api
# For Real Device (same network): http://<your-computer-ip>:8000/api (get IP: ipconfig getifaddr en0 or ifconfig)
# For Production: https://your-api-domain.com/api
API_BASE_URL=http://10.0.2.2:8000/api

# Environment
ENV=development

# Instructions:
# 1. Copy this file to .env: cp assets/.env.example assets/.env
# 2. Update the API_BASE_URL based on your testing platform (see comments above)
# 3. For production, use HTTPS production API URL
